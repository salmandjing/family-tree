# Copy to .env and fill in for a build that talks to the backup Worker.
# Both are OPTIONAL: with neither set, the app runs fully local-only
# (IndexedDB + export/import), no login screen tied to a Worker.

# Base path the app is served under on GitHub Pages.
#   "/tree/" for djsalman.dev/tree, or "/" for a subdomain (tree.djsalman.dev).
VITE_BASE=/tree/

# Backup Worker base URL. When set, the app shows the passphrase gate and
# performs Drive backups through this Worker.
# VITE_WORKER_URL=https://family-tree-backup.<your-subdomain>.workers.dev
